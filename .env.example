# ── Cleanverse Cooperate API v5 ───────────────────────────────────────────────
# Sandbox base URL (switch to https://api.cleanverse.com/api/cooperate for prod)
CLEANVERSE_API_BASE=https://uatapi.cleanverse.com/api/cooperate
# api-id: sent as header on every request
CLEANVERSE_APP_ID=APP20260614112550LIDZXM
# api-key: used LOCALLY to AES-encrypt request bodies — never sent over the wire
CLEANVERSE_API_KEY=qhfPE24VqLv7wTK7AXMkD4p2i7zKnerg84AtT0IGto0=

# ── Monad chain ───────────────────────────────────────────────────────────────
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
ARBITER_PRIVATE_KEY=0xYOUR_ARBITER_PRIVATE_KEY
ARBITER_ADDRESS=0xYOUR_ARBITER_ADDRESS

# ── PayHub contract (filled after deploy) ─────────────────────────────────────
PAYHUB_CONTRACT_ADDRESS=0x...
# aUSDC on Monad testnet (from query_deposit_atoken_list)
ATOKEN_ADDRESS=0xaC0893567D43C3E7e6e35a72803df05416C1f20D
# Origin USDC on Monad testnet
USDC_ADDRESS=0x534b2f3A21130d7a60830c2Df862319e593943A3
FEE_RECIPIENT=0xYOUR_FEE_RECIPIENT

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
ARBITER_AUTH_TOKEN=demo_arbiter_token
AUDIT_SIGNING_SECRET=change_this_in_production

# ── Frontend (Next.js public vars) ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_PAYHUB_CONTRACT=0x...  # filled after deploy
NEXT_PUBLIC_ATOKEN_ADDRESS=0xaC0893567D43C3E7e6e35a72803df05416C1f20D
NEXT_PUBLIC_ARBITER_TOKEN=demo_arbiter_token
